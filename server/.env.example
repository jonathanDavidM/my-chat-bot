# Copy this file to server/.env and fill in your real key.
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional. Comma-separated list of origins allowed to call /api/chat/send.
# If empty, only common localhost dev origins are accepted.
# ALLOWED_ORIGINS=https://your-portfolio.com,https://www.your-portfolio.com
