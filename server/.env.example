# Copy this file to server/.env and fill in your real key.
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional. Comma-separated list of origins allowed to call /api/chat/send.
# If empty, only common localhost dev origins are accepted.
# ALLOWED_ORIGINS=https://your-portfolio.com,https://www.your-portfolio.com

# Optional. If set, the send_contact_message agent tool delivers emails via Resend.
# If unset, the tool only logs to the server console.
# Get a key at https://resend.com/api-keys
# RESEND_API_KEY=your_resend_api_key_here

# Sender address. Until you verify a custom domain in Resend, use the shared sender below.
# Note: with the shared sender, Resend only allows delivery to the email of the Resend account owner.
# RESEND_FROM=onboarding@resend.dev

# Recipient (Jonathan's email). Defaults to magno.jonathan028@gmail.com if unset.
# CONTACT_RECIPIENT=magno.jonathan028@gmail.com
